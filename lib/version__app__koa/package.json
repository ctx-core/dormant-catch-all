{
	"name": "@ctx-core/version__app__koa",
	"version": "3.1.0",
	"description": "ctx-core version__app__koa",
	"main": "lib.js",
	"module": "lib.js",
	"types": "lib.ts",
	"scripts": {
		"build": "bun run copy-mjs && bun run compile",
		"clean": "rimraf tsconfig.tsbuildinfo && rm -f src/**/*.js && rm -f src/**/*.d.ts && rm -f src/**/*.map",
		"compile": "./node_modules/.bin/tsc -b ",
		"copy-mjs": "cd lib && echo \"module.exports = (async () => import('./index.js'))()\" > index.cjs",
		"prepublishOnly": "bun run clean && bun run build"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ctx-core/version__app__koa.git"
	},
	"keywords": [
		"ctx-core",
		"version__app__koa"
	],
	"author": "Brian Takita",
	"license": "Apache-2.0",
	"bugs": {
		"url": "https://github.com/ctx-core/version__app__koa/issues"
	},
	"homepage": "https://github.com/ctx-core/version__app__koa#readme",
	"publishConfig": {
		"access": "public",
		"cache": "~/.npm"
	},
	"devDependencies": {
		"typescript": "^5.9.3"
	},
	"gitHead": "6448b6e05c211aa42d0113841f4d2dd0b11c1bae"
}
